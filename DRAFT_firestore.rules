rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      // For this app, we require email verification if available, 
      // but some providers (like Google) verify it automatically.
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) 
          && data.uid == request.auth.uid 
          && data.email is string
          && data.uid is string;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.desire is string && data.desire.size() <= 1000
          && data.phase in ['before', 'during', 'after', 'completed']
          && (data.magnetStrength is number && data.magnetStrength >= 0)
          && (data.createdAt == request.time || !data.diff(existing()).affectedKeys().hasAny(['createdAt']));
    }

    function isValidRitual(data) {
      return data.userId == request.auth.uid
          && data.ritualName in ['fajr', 'dhuhr', 'asr', 'maghrib', 'isha']
          && data.timestamp == request.time
          && data.date is string;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);

      match /goals/{goalId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal(incoming());
        allow update: if isOwner(userId) && isValidGoal(incoming())
                      && (
                        // Prevent editing completed goals unless it's a specific "uncomplete" action (though we might not need it)
                        existing().phase != 'completed' 
                        || incoming().diff(existing()).affectedKeys().hasOnly(['isCompleted'])
                      );
        allow delete: if isOwner(userId);
      }

      match /rituals/{ritualId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRitual(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
